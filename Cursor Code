#!/usr/bin/env python3

import argparse
import base64
import csv
import os
import sys
import time
from dataclasses import dataclass
from email.message import EmailMessage
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple


SCOPES = ["https://www.googleapis.com/auth/gmail.send"]


class TemplateError(RuntimeError):
    pass


def _read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8").replace("\r\n", "\n")


def _first_name_from_name(name: str) -> str:
    name = (name or "").strip()
    if not name:
        return ""
    return name.split()[0]


def _safe_format(template: str, values: Dict[str, Any]) -> str:
    """
    Format with {placeholders}. If a key is missing, raise a helpful error
    listing available keys for that row.
    """
    class _Missing(dict):
        def __missing__(self, key: str) -> str:  # type: ignore[override]
            raise KeyError(key)

    try:
        return template.format_map(_Missing(values))
    except KeyError as e:
        missing = str(e).strip("'")
        available = ", ".join(sorted(values.keys()))
        raise TemplateError(
            f"Template placeholder {{{missing}}} not found in CSV row. "
            f"Available keys: {available}"
        ) from None


def _get_gmail_service(project_dir: Path) -> Any:
    # Import lazily so `--dry-run` works without Google deps/noisy warnings.
    from google.auth.transport.requests import Request
    from google.oauth2.credentials import Credentials
    from google_auth_oauthlib.flow import InstalledAppFlow
    from googleapiclient.discovery import build

    creds_path = project_dir / "credentials.json"
    token_path = project_dir / "token.json"

    if not creds_path.exists():
        raise FileNotFoundError(
            f"Missing {creds_path}. Download OAuth client credentials JSON "
            f"from Google Cloud Console and save it as credentials.json."
        )

    creds: Optional[Credentials] = None
    if token_path.exists():
        creds = Credentials.from_authorized_user_file(str(token_path), SCOPES)

    if not creds or not creds.valid:
        if creds and creds.expired and creds.refresh_token:
            creds.refresh(Request())
        else:
            flow = InstalledAppFlow.from_client_secrets_file(str(creds_path), SCOPES)
            creds = flow.run_local_server(port=0)
        token_path.write_text(creds.to_json(), encoding="utf-8")

    return build("gmail", "v1", credentials=creds)


def _build_message(
    *,
    to_email: str,
    subject: str,
    body: str,
    sender_display: Optional[str],
    reply_to: Optional[str],
    cc: Optional[str],
    bcc: Optional[str],
) -> Dict[str, str]:
    msg = EmailMessage()
    msg["To"] = to_email
    if sender_display:
        msg["From"] = sender_display
    msg["Subject"] = subject
    if reply_to:
        msg["Reply-To"] = reply_to
    if cc:
        msg["Cc"] = cc
    if bcc:
        msg["Bcc"] = bcc
    msg.set_content(body)

    raw = base64.urlsafe_b64encode(msg.as_bytes()).decode("utf-8")
    return {"raw": raw}


def _send_message(service: Any, user_id: str, message_body: Dict[str, str]) -> str:
    sent = service.users().messages().send(userId=user_id, body=message_body).execute()
    return sent.get("id", "")


def _load_rows(csv_path: Path) -> List[Dict[str, str]]:
    with csv_path.open("r", encoding="utf-8-sig", newline="") as f:
        reader = csv.DictReader(f)
        if not reader.fieldnames:
            raise ValueError("CSV appears to have no header row.")
        rows = []
        for i, row in enumerate(reader, start=2):  # header is line 1
            normalized = {k.strip(): (v or "").strip() for k, v in row.items() if k is not None}
            normalized["_csv_line"] = str(i)
            rows.append(normalized)
        return rows


def _require(row: Dict[str, str], key: str) -> str:
    val = (row.get(key) or "").strip()
    if not val:
        raise ValueError(f"Missing required column '{key}' (CSV line {row.get('_csv_line','?')}).")
    return val


@dataclass(frozen=True)
class RunConfig:
    csv_path: Path
    subject_template: str
    body_template: str
    user_id: str
    sender_name: str
    company: str
    signature: str
    from_display: Optional[str]
    reply_to: Optional[str]
    cc: Optional[str]
    bcc: Optional[str]
    dry_run: bool
    limit: Optional[int]
    sleep_s: float


def _render_for_row(cfg: RunConfig, row: Dict[str, str]) -> Tuple[str, str, str]:
    name = row.get("name", "").strip()
    first_name = row.get("first_name", "").strip() or _first_name_from_name(name) or "there"
    email = _require(row, "email")

    values: Dict[str, Any] = dict(row)
    values.update(
        {
            "name": name,
            "first_name": first_name,
            "sender_name": cfg.sender_name,
            "company": cfg.company,
            "signature": cfg.signature,
        }
    )

    subject = _safe_format(cfg.subject_template, values).strip()
    body = _safe_format(cfg.body_template, values).strip() + "\n"
    return email, subject, body


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Send personalized outreach emails from a CSV using the Gmail API."
    )
    parser.add_argument("--csv", dest="csv_path", required=True, help="Path to CSV with at least columns: email, name (optional).")
    parser.add_argument(
        "--subject-template",
        default=str(Path("templates") / "default_subject.txt"),
        help="Path to subject template text file (uses {placeholders}).",
    )
    parser.add_argument(
        "--body-template",
        default=str(Path("templates") / "default_body.txt"),
        help="Path to body template text file (uses {placeholders}).",
    )
    parser.add_argument("--sender-name", default="", help="Used for {sender_name}.")
    parser.add_argument("--company", default="", help="Used for {company}.")
    parser.add_argument("--signature", default="", help="Used for {signature} (e.g., phone/website).")
    parser.add_argument(
        "--from-display",
        default=None,
        help='Optional "From" display header. Example: "Your Name <me@gmail.com>". '
        "If omitted, Gmail uses the account's default.",
    )
    parser.add_argument("--reply-to", default=None, help="Optional Reply-To email.")
    parser.add_argument("--cc", default=None, help="Optional CC (comma-separated).")
    parser.add_argument("--bcc", default=None, help="Optional BCC (comma-separated).")
    parser.add_argument("--user-id", default="me", help='Gmail userId, usually "me".')
    parser.add_argument("--dry-run", action="store_true", help="Print what would be sent, but don't send.")
    parser.add_argument("--limit", type=int, default=None, help="Only process first N rows.")
    parser.add_argument("--sleep", type=float, default=0.8, help="Seconds to sleep between sends.")
    args = parser.parse_args()

    project_dir = Path(__file__).resolve().parent
    csv_path = Path(args.csv_path).expanduser().resolve()
    if not csv_path.exists():
        print(f"CSV not found: {csv_path}", file=sys.stderr)
        return 2

    subject_template = _read_text((project_dir / args.subject_template).resolve()
                                 if not os.path.isabs(args.subject_template)
                                 else Path(args.subject_template))
    body_template = _read_text((project_dir / args.body_template).resolve()
                               if not os.path.isabs(args.body_template)
                               else Path(args.body_template))

    cfg = RunConfig(
        csv_path=csv_path,
        subject_template=subject_template,
        body_template=body_template,
        user_id=args.user_id,
        sender_name=args.sender_name.strip(),
        company=args.company.strip(),
        signature=args.signature.strip(),
        from_display=args.from_display,
        reply_to=args.reply_to,
        cc=args.cc,
        bcc=args.bcc,
        dry_run=bool(args.dry_run),
        limit=args.limit,
        sleep_s=float(args.sleep),
    )

    rows = _load_rows(cfg.csv_path)
    if cfg.limit is not None:
        rows = rows[: max(cfg.limit, 0)]

    if not rows:
        print("No rows found in CSV.")
        return 0

    service = None if cfg.dry_run else _get_gmail_service(project_dir)

    sent_count = 0
    for idx, row in enumerate(rows, start=1):
        try:
            to_email, subject, body = _render_for_row(cfg, row)
        except Exception as e:
            print(f"[row {idx}] ERROR: {e}", file=sys.stderr)
            continue

        if cfg.dry_run:
            print("=" * 72)
            print(f"TO: {to_email}")
            print(f"SUBJECT: {subject}")
            print("-" * 72)
            print(body.rstrip("\n"))
            continue

        message_body = _build_message(
            to_email=to_email,
            subject=subject,
            body=body,
            sender_display=cfg.from_display,
            reply_to=cfg.reply_to,
            cc=cfg.cc,
            bcc=cfg.bcc,
        )

        try:
            msg_id = _send_message(service, cfg.user_id, message_body)  # type: ignore[arg-type]
            sent_count += 1
            print(f"[{idx}/{len(rows)}] Sent to {to_email} (id={msg_id})")
        except Exception as e:
            print(f"[{idx}/{len(rows)}] SEND ERROR to {to_email}: {e}", file=sys.stderr)

        if cfg.sleep_s > 0:
            time.sleep(cfg.sleep_s)

    if cfg.dry_run:
        print("=" * 72)
        print(f"Dry run complete. Rendered {len(rows)} emails.")
    else:
        print(f"Done. Successfully sent {sent_count}/{len(rows)} emails.")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
